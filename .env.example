# ================================
# DJANGO CORE SETTINGS
# ================================
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ================================
# EMAIL CONFIGURATION (SendGrid)
# ================================
SENDGRID_API_KEY=your_sendgrid_api_key_here
DEFAULT_FROM_EMAIL=noreply@anitoki.com

# ================================
# DATABASE CONFIGURATION
# ================================

# --- Development (SQLite - Default) ---
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# --- Production - OPCIÓN 1: Render PostgreSQL (RECOMENDADO para proyectos de curso) ---
# Render crea automáticamente la variable DATABASE_URL cuando agregas PostgreSQL.
# NO necesitas configurar nada manualmente - Render lo hace por ti.
# Ventajas: Todo en un solo lugar, gratis 90 días, más simple.
# 
# ¡No agregues DATABASE_URL aquí! Render lo genera automáticamente.

# --- Production - OPCIÓN 2: Supabase PostgreSQL (Alternativa) ---
# Si prefieres usar Supabase en lugar de Render PostgreSQL:
# 
# 1. Crea proyecto en app.supabase.com
# 2. Settings → Database → Connection string → URI
# 3. Formato: postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
# 4. Agrega esta variable en Render:
#
# DATABASE_URL=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres
#
# Ventajas: Gratis permanentemente, dashboard visual, no expira.

# ================================
# CORS SETTINGS
# ================================

# Development
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Production (actualiza con tus URLs de Render)
# CORS_ALLOWED_ORIGINS=https://anitoki-frontend.onrender.com

# ================================
# CSRF SETTINGS
# ================================

# Development
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Production (actualiza con tus URLs de Render)
# CSRF_TRUSTED_ORIGINS=https://anitoki-backend.onrender.com,https://anitoki-frontend.onrender.com
